<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:EasySaveConsole"
    x:Class="EasySaveConsole.SettingsWindow"
    Title="{Binding [settings.title], Source={x:Static local:LanguageService.Instance}}"
    Width="420" SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    CanResize="False">
    <DockPanel Margin="20">
        <TextBlock DockPanel.Dock="Top"
            Text="{Binding [settings.title], Source={x:Static local:LanguageService.Instance}}"
            FontSize="18" FontWeight="Bold" Margin="0,0,0,20" />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
            HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
            <Button x:Name="SaveButton"
                Content="{Binding [settings.save], Source={x:Static local:LanguageService.Instance}}"
                Padding="20,6" />
            <Button x:Name="CancelButton"
                Content="{Binding [settings.cancel], Source={x:Static local:LanguageService.Instance}}"
                Padding="20,6" />
        </StackPanel>

        <StackPanel Spacing="16">
            <StackPanel Spacing="4">
                <TextBlock
                    Text="{Binding [settings.language.label], Source={x:Static local:LanguageService.Instance}}"
                    FontWeight="SemiBold" />
                <ComboBox x:Name="LanguageCombo" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="English" />
                    <ComboBoxItem Content="Français" />
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock
                    Text="{Binding [settings.log.format.label], Source={x:Static local:LanguageService.Instance}}"
                    FontWeight="SemiBold" />
                <ComboBox x:Name="LogFormatCombo" HorizontalAlignment="Stretch">
                    <ComboBoxItem Content="JSON" />
                    <ComboBoxItem Content="XML" />
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock
                    Text="{Binding [settings.excludes.processes.label], Source={x:Static local:LanguageService.Instance}}"
                    FontWeight="SemiBold" />
                <TextBox x:Name="ExcludeProcessesInput" AcceptsReturn="True" Height="100"
                    PlaceholderText="{Binding [settings.excludes.processes.placeholder], Source={x:Static local:LanguageService.Instance}}" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock
                    Text="{Binding [settings.encrypt.extensions.label], Source={x:Static local:LanguageService.Instance}}"
                    FontWeight="SemiBold" />
                <TextBox x:Name="EncryptExtensionsInput" PlaceholderText=".txt;.pdf" />
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock
                    Text="{Binding [settings.transfer.size.label], Source={x:Static local:LanguageService.Instance}}"
                    FontWeight="SemiBold" />
                <NumericUpDown
                    x:Name="BigFileSizeInput"
                    Minimum="10"
                    Increment="10" />
            </StackPanel>

        </StackPanel>
    </DockPanel>
</Window>