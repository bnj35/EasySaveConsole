<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:EasySaveConsole"
        x:Class="EasySaveConsole.MainWindow"
        Width="900" Height="600"
        Title="EasySave - Backup Manager">
    <DockPanel>
        <!-- Title Bar -->
        <TextBlock DockPanel.Dock="Top" Text="EasySave Backup Manager"
            FontSize="18" FontWeight="Bold" Margin="12" />

        <!-- Main Content -->
        <Grid DockPanel.Dock="Top" Margin="12" ColumnDefinitions="*,*">
            <!-- Left: Job Creation -->
            <StackPanel Grid.Column="0" Margin="0,0,12,0" Spacing="8">
                <TextBlock Text="Create New Job" FontSize="14" FontWeight="Bold" />

                <StackPanel Spacing="4">
                    <TextBlock Text="Job Name:" />
                    <TextBox x:Name="JobNameInput" PlaceholderText="Enter job name" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Source Directory:" />
                    <TextBox x:Name="SourceDirInput" PlaceholderText="Full path" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Target Directory:" />
                    <TextBox x:Name="TargetDirInput" PlaceholderText="Full path" />
                </StackPanel>

                <StackPanel Spacing="4">
                    <TextBlock Text="Backup Type:" />
                    <ComboBox x:Name="BackupTypeCombo">
                        <ComboBoxItem>Full Backup</ComboBoxItem>
                        <ComboBoxItem>Incremental</ComboBoxItem>
                    </ComboBox>
                </StackPanel>

                <CheckBox x:Name="EncryptCheck" Content="Encrypt backup (CryptoSoft)" />

                <Button x:Name="CreateJobButton" Content="Create Job" Padding="8,4" />
            </StackPanel>

            <!-- Right: Job List & Actions -->
            <StackPanel Grid.Column="1" Spacing="8">
                <TextBlock Text="Backup Jobs" FontSize="14" FontWeight="Bold" />

                <ListBox x:Name="JobsList" Height="250" SelectionMode="Multiple">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="local:BackupJob">
                            <StackPanel Margin="4">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                <TextBlock Text="{Binding SourceDir}" FontSize="11"
                                    Foreground="Gray" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <StackPanel Spacing="4" Orientation="Horizontal">
                    <Button x:Name="RunSelectedButton" Content="Run Selected" Padding="8,4" />
                    <Button x:Name="DeleteJobButton" Content="Delete" Padding="8,4" />
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Progress Section -->
        <DockPanel DockPanel.Dock="Top" Margin="12" Height="100">
            <TextBlock DockPanel.Dock="Top" Text="Running Jobs:" FontWeight="Bold" />
            <ListBox x:Name="ActiveJobsList">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="local:ActiveJob">
                        <StackPanel Margin="4" Spacing="4">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                            <ProgressBar Value="{Binding Progression}" Height="12" />
                            <TextBlock
                                Text="{Binding NumberFilesRemaining, StringFormat='Remaining files: {0}'}"
                                FontSize="11" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <!-- Status Bar -->
        <TextBlock x:Name="StatusMessage" DockPanel.Dock="Bottom" Text="Ready"
            Margin="12,8" Foreground="Gray" />
    </DockPanel>
</Window>